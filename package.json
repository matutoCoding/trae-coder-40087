{
  "name": "charging-pile-sharing",
  "version": "1.0.0",
  "description": "小区充电桩共享桌面客户端",
  "main": "dist-electron/main/index.js",
  "author": "Trae",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "pinia": "^2.1.7",
    "element-plus": "^2.4.4",
    "@element-plus/icons-vue": "^2.3.1",
    "dayjs": "^1.11.10"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vite-plugin-electron": "^0.15.5",
    "vite-plugin-electron-renderer": "^0.14.5",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vue-tsc": "^1.8.25",
    "@types/node": "^20.10.6",
    "sass": "^1.69.5"
  },
  "build": {
    "appId": "com.charging.pile",
    "productName": "充电桩共享系统",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
